# ═══════════════════════════════════════════════════════════════
# Centralised Exchange — Environment Variables
# Copy to .env and update values for your environment
# ═══════════════════════════════════════════════════════════════

# ─── Database (PostgreSQL / TimescaleDB) ───
DB_USER=your_user
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=my_database

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── API Server ───
API_PORT=3000
CORS_ORIGIN=http://localhost:3000,http://localhost:3005
ACCESS_TOKEN_SECRET=change-this-access-secret-in-production
REFRESH_TOKEN_SECRET=change-this-refresh-secret-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_SECONDS=604800

# ─── WebSocket Server ───
WS_PORT=3001

# ─── Engine ───
WITH_SNAPSHOT=true
ENGINE_SNAPSHOT_INTERVAL=30000
ENGINE_LOG_MESSAGES=false

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_API_TIMEOUT_MS=60000
